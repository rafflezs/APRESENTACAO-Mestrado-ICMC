 @article{Fitzpatrick_Farrell_Richter_Zeunik_1987,
    title        = {An automated staff scheduling system that minimizes payroll costs and maximizes nurse satisfaction},
    volume       = {5},
    abstractnote = {In 1985 the Nursing Executive Board at Grant Hospital of Chicago appointed a task force to investigate and objectively evaluate all aspects of the staffing process. Internal audits showed that nurse scheduling was inefficient and produced dissatisfaction and high turnover. General Optimization Inc. of Chicago asked Grant Hospital to serve as a beta test site for their “What’s Best” nurse scheduling software. This program provides the best possible nurse schedule by optimizing a staff scheduling model using Lotus 1-2-3. The program handles variables such as multiple skill or specialization levels; specification or non-patient care requirements; addition or deletion of staff members; changes in work rules and work patterns; seniority and performance considerations in nurse assignments. Results of the pilot study are reviewed: substantial costs were saved, initial training of staff could be kept to a minimum and job performance and satisfaction improved.},
    number       = {1},
    journal      = {Computers in Nursing},
    author       = {Fitzpatrick, T. and Farrell, L.Y. and Richter-Zeunik, M.},
    year         = {1987},
    pages        = {10–14}
}

